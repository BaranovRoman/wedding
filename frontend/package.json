{
    "name": "next-boilerplate",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "watch": "next dev",
        "build": "next build",
        "ba": "ANALYZE=true next build",
        "start": "next start",
        "lint": "next lint",
        "format": "prettier --ignore-unknown --write \"src/**/*\"",
        "tsc": "tsc --noEmit --pretty",
        "subsetting": "node ./subset-fonts.js",
        "storybook": "storybook dev -p 6006",
        "test-storybook": "test-storybook",
        "build-storybook": "storybook build -o storybook",
        "test": "jest ./src --passWithNoTests",
        "test:watch": "jest ./src --watch",
        "test:general": "npx playwright test tests/general/*",
        "test:lh": "npx playwright test tests/lighthouse/* --config=playwright.config.lighthouse.ts",
        "test:screenshot": "npx playwright test tests/screenshot/* --config=playwright.config.screenshot.ts",
        "test:screenshot:update": "npx playwright test tests/screenshot/* --config=playwright.config.screenshot.ts --update-snapshots",
        "test:all": "npm run test:lh && npm run test:general",
        "prepare": "cd .. && husky install frontend/.husky"
    },
    "browserslist": [
        "Android >= 8",
        "iOS >= 14",
        "Safari >= 14",
        "last 2 Edge versions",
        "last 2 Chrome versions",
        "last 2 ChromeAndroid versions",
        "last 2 Firefox versions",
        "last 2 Opera versions"
    ],
    "dependencies": {
        "@playwright/test": "^1.34.0",
        "@react-three/drei": "^9.68.3",
        "@react-three/fiber": "^8.13.0",
        "@react-three/postprocessing": "^2.14.12",
        "@types/node": "^20.2.1",
        "@types/react": "^18.2.6",
        "@types/react-dom": "^18.2.4",
        "axios": "^1.4.0",
        "classnames": "^2.3.2",
        "eslint": "^8.41.0",
        "eslint-config-next": "^13.4.3",
        "gsap": "^3.12.1",
        "lodash.debounce": "^4.0.8",
        "next": "^13.4.3",
        "r3f-perf": "^7.1.2",
        "raw-loader": "^4.0.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-transition-group": "^4.4.5",
        "recoil": "^0.7.7",
        "sass-loader": "^13.2.2",
        "sharp": "^0.32.1",
        "three": "^0.152.2",
        "typograf": "^7.1.0",
        "vanilla-lazyload": "^17.8.3"
    },
    "devDependencies": {
        "@mdx-js/react": "^2.3.0",
        "@next/bundle-analyzer": "^13.4.3",
        "@storybook/addon-a11y": "^7.0.12",
        "@storybook/addon-actions": "^7.0.12",
        "@storybook/addon-docs": "^7.0.12",
        "@storybook/addon-essentials": "^7.0.12",
        "@storybook/addon-interactions": "^7.0.12",
        "@storybook/addon-links": "^7.0.12",
        "@storybook/addon-styling": "^1.0.6",
        "@storybook/jest": "^0.1.0",
        "@storybook/mdx2-csf": "^1.1.0",
        "@storybook/nextjs": "^7.0.12",
        "@storybook/react": "^7.0.12",
        "@storybook/test-runner": "^0.10.0",
        "@storybook/testing-library": "^0.1.0",
        "@svgr/webpack": "^8.0.1",
        "@testing-library/jest-dom": "^5.16.5",
        "@testing-library/react": "^14.0.0",
        "@types/html-validator": "^5.0.3",
        "@types/lodash.debounce": "^4.0.7",
        "@types/sharp": "^0.31.1",
        "autoprefixer": "^10.4.14",
        "axe-core": "^4.7.1",
        "cssnano": "^6.0.1",
        "eslint-config-prettier": "^8.8.0",
        "eslint-plugin-storybook": "^0.6.12",
        "glslify-loader": "^2.0.0",
        "html-validator": "^6.0.1",
        "husky": "^8.0.3",
        "lighthouse": "^10.2.0",
        "lint-staged": "^13.2.2",
        "msw-storybook-addon": "^1.8.0",
        "playwright": "^1.34.0",
        "postcss-clamp": "^4.1.0",
        "postcss-easings": "^3.0.1",
        "postcss-focus-visible": "^8.0.2",
        "postcss-focus-within": "^7.0.2",
        "postcss-font-display": "^0.3.0",
        "prettier": "^2.8.8",
        "sass": "^1.62.1",
        "storybook": "^7.0.12",
        "storybook-addon-designs": "^6.3.1",
        "storybook-addon-swc": "^1.2.0",
        "tsc-files": "^1.1.3",
        "tsconfig-paths-webpack-plugin": "^4.0.1",
        "typescript": "^4.9.5",
        "webpack-log": "^3.0.2"
    },
    "msw": {
        "workerDirectory": "public"
    }
}
